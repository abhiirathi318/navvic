# Google Gemini API key (free tier). Get one at https://aistudio.google.com/apikey
# Used by the HS Code Classifier tool (/api/hs-code).
GEMINI_API_KEY=your_gemini_api_key_here

# Resend — quote form emails (/api/quote). Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Sender address (must be a verified domain in Resend). Use onboarding@resend.dev for testing.
RESEND_FROM=Navvic <onboarding@resend.dev>
# Where quote requests are delivered (defaults to support@navvic.com)
QUOTE_TO_EMAIL=support@navvic.com
